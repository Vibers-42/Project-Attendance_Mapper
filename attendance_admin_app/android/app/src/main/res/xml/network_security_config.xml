<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow local HTTP during development (backend runs on http:// not https://) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
